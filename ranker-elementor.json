{\n  "elementor_version": "3.0.0",\n  "elementor_build": "1",\n  "version": "1.0.0",\n  "title": "Homestay Ranker",\n  "panels": {\n    "elements": {\n      "categories": {\n        "basic": {\n          "title": "Basic"\n        },\n        "ratings": {\n          "title": "Ratings & Rankings"\n        },\n        "homestays": {\n          "title": "Homestay Elements"\n        }\n      },\n      "widgets": [\n        {\n          "name": "homestay_ranker_list",\n          "title": "Homestay Ranker List",\n          "icon": "eicon-posts-grid",\n          "category": "homestays",\n          "keywords": ["homestay", "list", "ranking"],\n          "settings": {\n            "filters": {\n              "label": "Filters",\n              "type": "section",\n              "fields": {\n                "location": {\n                  "label": "Location",\n                  "type": "select",\n                  "options": {\n                    "darjeeling": "Darjeeling",\n                    "sikkim": "Sikkim",\n                    "kalimpong": "Kalimpong",\n                    "all": "All Locations"\n                  }\n                },\n                "price_range": {\n                  "label": "Price Range",\n                  "type": "slider",\n                  "min": 0,\n                  "max": 10000,\n                  "step": 100\n                },\n                "min_rating": {\n                  "label": "Minimum Rating",\n                  "type": "slider",\n                  "min": 1,\n                  "max": 5,\n                  "step": 0.5\n                }\n              }\n            },\n            "layout": {\n              "label": "Layout",\n              "type": "section",\n              "fields": {\n                "layout_type": {\n                  "label": "Display Type",\n                  "type": "select",\n                  "options": {\n                    "grid": "Grid",\n                    "list": "List",\n                    "carousel": "Carousel"\n                  }\n                },\n                "columns": {\n                  "label": "Columns",\n                  "type": "select",\n                  "options": {\n                    "1": "1 Column",\n                    "2": "2 Columns",\n                    "3": "3 Columns",\n                    "4": "4 Columns"\n                  }\n                }\n              }\n            }\n          }\n        },\n        {\n          "name": "homestay_card",\n          "title": "Homestay Card",\n          "icon": "eicon-product",\n          "category": "homestays",\n          "keywords": ["homestay", "card", "single"],\n          "settings": {\n            "content": {\n              "label": "Content",\n              "type": "section",\n              "fields": {\n                "homestay_id": {\n                  "label": "Homestay ID",\n                  "type": "text"\n                },\n                "show_image": {\n                  "label": "Show Image",\n                  "type": "switcher",\n                  "default": "yes"\n                },\n                "show_rating": {\n                  "label": "Show Rating",\n                  "type": "switcher",\n                  "default": "yes"\n                },\n                "show_price": {\n                  "label": "Show Price",\n                  "type": "switcher",\n                  "default": "yes"\n                }\n              }\n            },\n            "style": {\n              "label": "Style",\n              "type": "section",\n              "fields": {\n                "card_style": {\n                  "label": "Card Style",\n                  "type": "select",\n                  "options": {\n                    "modern": "Modern",\n                    "classic": "Classic",\n                    "minimal": "Minimal"\n                  }\n                }\n              }\n            }\n          }\n        },\n        {\n          "name": "rating_widget",\n          "title": "Rating Widget",\n          "icon": "eicon-star",\n          "category": "ratings",\n          "keywords": ["rating", "stars", "review"],\n          "settings": {\n            "rating": {\n              "label": "Rating Settings",\n              "type": "section",\n              "fields": {\n                "rating_value": {\n                  "label": "Rating Value",\n                  "type": "slider",\n                  "min": 1,\n                  "max": 5,\n                  "step": 0.5\n                },\n                "show_count": {\n                  "label": "Show Review Count",\n                  "type": "switcher",\n                  "default": "yes"\n                },\n                "review_count": {\n                  "label": "Review Count",\n                  "type": "number"\n                }\n              }\n            }\n          }\n        }\n      ]\n    }\n  },\n  "data_source": {\n    "api_endpoint": "/api/homestays",\n    "methods": {\n      "get_homestays": {\n        "endpoint": "/api/homestays",\n        "method": "GET",\n        "params": ["location", "price_min", "price_max", "rating_min", "sort_by"]\n      },\n      "get_homestay_details": {\n        "endpoint": "/api/homestays/{id}",\n        "method": "GET"\n      },\n      "submit_rating": {\n        "endpoint": "/api/homestays/{id}/rate",\n        "method": "POST",\n        "body": ["rating", "review", "user_id"]\n      }\n    }\n  },\n  "styling_options": {\n    "colors": {\n      "primary": "#3498db",\n      "secondary": "#2ecc71",\n      "accent": "#e74c3c",\n      "text": "#2c3e50",\n      "background": "#ecf0f1"\n    },\n    "typography": {\n      "heading_font": "Poppins",\n      "body_font": "Inter",\n      "heading_size": "24px",\n      "body_size": "14px"\n    }\n  }\n}